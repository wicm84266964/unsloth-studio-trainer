{
  "model_name": "Qwen/Qwen3.5-0.8B",
  "training_type": "LoRA/QLoRA",
  "load_in_4bit": false,
  "max_seq_length": 2048,
  "local_datasets": [
    "<absolute path to cleaned_dataset.utf8.jsonl>"
  ],
  "format_type": "sharegpt",
  "num_epochs": 3,
  "learning_rate": "2e-4",
  "batch_size": 1,
  "gradient_accumulation_steps": 4,
  "warmup_steps": 10,
  "max_steps": 0,
  "save_steps": 100,
  "weight_decay": 0.01,
  "random_seed": 3407,
  "packing": false,
  "optim": "adamw_8bit",
  "lr_scheduler_type": "linear",
  "use_lora": true,
  "lora_r": 16,
  "lora_alpha": 16,
  "lora_dropout": 0.0,
  "target_modules": [
    "q_proj",
    "k_proj",
    "v_proj",
    "o_proj",
    "gate_proj",
    "up_proj",
    "down_proj"
  ],
  "gradient_checkpointing": "unsloth",
  "use_rslora": false,
  "use_loftq": false,
  "train_on_completions": false,
  "finetune_vision_layers": false,
  "finetune_language_layers": true,
  "finetune_attention_modules": true,
  "finetune_mlp_modules": true,
  "is_dataset_image": false,
  "is_dataset_audio": false,
  "is_embedding": false,
  "enable_wandb": false,
  "enable_tensorboard": false,
  "output_dir": "<absolute path to output_dir>",
  "tensorboard_dir": "<absolute path to tensorboard_dir>",
  "trust_remote_code": false,
  "gpu_ids": [0, 1]
}
